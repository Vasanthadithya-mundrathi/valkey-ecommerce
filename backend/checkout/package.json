{
  "name": "valkey-checkout-backend",
  "version": "0.1.0",
  "private": true,
  "description": "BullMQ checkout workflow backed by Valkey for the Valkey e-commerce demo.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "seed": "tsx src/seed.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.77.1",
    "express": "^4.21.2",
    "ioredis": "^5.10.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/node": "^25.9.1",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7"
  }
}
