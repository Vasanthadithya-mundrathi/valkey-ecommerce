# Backend port
PORT=4000

# Identifier for this node (useful when running multiple replicas behind the
# Valkey-backed socket.io adapter so you can see which node served a client).
NODE_ID=node1

# Valkey connection. Valkey speaks the Redis protocol, so the redis client
# library and @socket.io/redis-adapter work as drop-in replacements.
VALKEY_URL=redis://localhost:6379

# CORS origin for the React frontend
CORS_ORIGIN=http://localhost:3000
