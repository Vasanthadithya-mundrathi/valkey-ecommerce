# Copy to .env and adjust if needed.
# Valkey connection (valkey-bundle image: includes JSON, Search, Bloom modules)
VALKEY_URL=redis://localhost:6379

# Backend HTTP port
PORT=4000

# Allowed frontend origin for CORS (React dev server)
CORS_ORIGIN=http://localhost:3000

# Challenge 14 — Agentic Search (Google Gemini). Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
